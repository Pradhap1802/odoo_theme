<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.website.industry.theme</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="website.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//app[@name='website']/block[@id='website_settings']" position="after">
                <block title="Intelligent Industry Theme" id="industry_theme_settings_block" invisible="not website_id">
                    <setting string="Active Theme" help="Select an industry theme category to instantly transform site layouts, colors and elements.">
                        <div class="content-group">
                            <div class="row mt8">
                                <label class="col-lg-3 o_light_label" string="Industry Theme" for="industry_theme_id"/>
                                <div class="col-lg-9">
                                    <field name="industry_theme_id" options="{'no_create': True, 'no_open': True}"/>
                                </div>
                            </div>
                            <div class="row mt8" invisible="not recommended_theme_id">
                                <div class="col-lg-12">
                                    <div class="alert alert-info d-flex align-items-center justify-content-between p-2 mt-2 mb-0" role="status">
                                        <div>
                                            <i class="oi oi-info-large me-2"/>
                                            <span>We recommend: </span>
                                            <strong><field name="recommended_theme_id" readonly="1"/></strong>
                                            <span> based on your products list.</span>
                                        </div>
                                        <button name="action_apply_recommended_theme" 
                                                type="object" 
                                                string="Apply" 
                                                class="btn btn-sm btn-link p-0 text-decoration-underline" 
                                                icon="oi-arrow-right"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>
