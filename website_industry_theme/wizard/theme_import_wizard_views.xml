<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_theme_import_wizard_form" model="ir.ui.view">
        <field name="name">industry.theme.import.wizard.form</field>
        <field name="model">industry.theme.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Import Industry Theme">
                <sheet>
                    <group>
                        <field name="file" filename="file_name"/>
                        <field name="file_name" invisible="1"/>
                        <field name="category_id" options="{'no_create': True}"/>
                    </group>
                    <footer>
                        <button name="action_import" string="Import" type="object" class="btn-primary"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_theme_import_wizard" model="ir.actions.act_window">
        <field name="name">Import Industry Theme</field>
        <field name="res_model">industry.theme.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
