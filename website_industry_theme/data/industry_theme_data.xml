<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- CATEGORIES SEED -->
        <record id="cat_vegetables" model="industry.theme.category">
            <field name="name">Vegetables</field>
            <field name="code">vegetables</field>
            <field name="description">Fresh farm produce, vegetables, fruits, and organic grocery stores.</field>
        </record>

        <record id="cat_fashion" model="industry.theme.category">
            <field name="name">Fashion</field>
            <field name="code">fashion</field>
            <field name="description">Premium boutique, accessories, lookbook editorial and luxury wear.</field>
        </record>

        <record id="cat_manufacturing" model="industry.theme.category">
            <field name="name">Manufacturing</field>
            <field name="code">manufacturing</field>
            <field name="description">Industrial engineering, factories, raw materials and B2B systems.</field>
        </record>

        <record id="cat_restaurant" model="industry.theme.category">
            <field name="name">Restaurant</field>
            <field name="code">restaurant</field>
            <field name="description">Cozy dining, chefs specials, bistros, bakeries and cafés.</field>
        </record>

        <record id="cat_pharmacy" model="industry.theme.category">
            <field name="name">Pharmacy</field>
            <field name="code">pharmacy</field>
            <field name="description">Trustworthy healthcare, clinical advice, doctor consultation and emergency medicines.</field>
        </record>

        <!-- PALETTES SEED -->
        <record id="palette_vegetables" model="industry.theme.palette">
            <field name="name">Natural Green Palette</field>
            <field name="primary_color">#2E7D32</field>
            <field name="secondary_color">#81C784</field>
            <field name="accent_color">#FF9800</field>
            <field name="bg_color">#F1F8E9</field>
        </record>

        <record id="palette_fashion" model="industry.theme.palette">
            <field name="name">Luxury Black Gold Palette</field>
            <field name="primary_color">#111111</field>
            <field name="secondary_color">#8D6E63</field>
            <field name="accent_color">#D4AF37</field>
            <field name="bg_color">#FFFFFF</field>
        </record>

        <record id="palette_manufacturing" model="industry.theme.palette">
            <field name="name">Industrial Dark Blue Palette</field>
            <field name="primary_color">#0D47A1</field>
            <field name="secondary_color">#546E7A</field>
            <field name="accent_color">#FFB300</field>
            <field name="bg_color">#ECEFF1</field>
        </record>

        <record id="palette_restaurant" model="industry.theme.palette">
            <field name="name">Cozy Orange Coffee Palette</field>
            <field name="primary_color">#BF360C</field>
            <field name="secondary_color">#3E2723</field>
            <field name="accent_color">#FFB300</field>
            <field name="bg_color">#FFF8E1</field>
        </record>

        <record id="palette_pharmacy" model="industry.theme.palette">
            <field name="name">Trustworthy Minty Teal Palette</field>
            <field name="primary_color">#00897B</field>
            <field name="secondary_color">#0288D1</field>
            <field name="accent_color">#E53935</field>
            <field name="bg_color">#E0F2F1</field>
        </record>

        <!-- TYPOGRAPHY FONTS SEED -->
        <record id="font_vegetables" model="industry.theme.font">
            <field name="name">Outfit Sans</field>
            <field name="font_family">'Outfit', sans-serif</field>
            <field name="font_url">https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700&amp;display=swap</field>
        </record>

        <record id="font_fashion" model="industry.theme.font">
            <field name="name">Playfair Display &amp; Montserrat</field>
            <field name="font_family">'Playfair Display', serif</field>
            <field name="font_url">https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&amp;family=Montserrat:wght@300;400;600&amp;display=swap</field>
        </record>

        <record id="font_manufacturing" model="industry.theme.font">
            <field name="name">Roboto Clean</field>
            <field name="font_family">'Roboto', sans-serif</field>
            <field name="font_url">https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&amp;display=swap</field>
        </record>

        <record id="font_restaurant" model="industry.theme.font">
            <field name="name">Lora &amp; Comfortaa</field>
            <field name="font_family">'Lora', serif</field>
            <field name="font_url">https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,600;1,400&amp;family=Comfortaa:wght@400;600&amp;display=swap</field>
        </record>

        <record id="font_pharmacy" model="industry.theme.font">
            <field name="name">Inter Medical</field>
            <field name="font_family">'Inter', sans-serif</field>
            <field name="font_url">https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&amp;display=swap</field>
        </record>

        <!-- LAYOUT STYLES SEED -->
        <record id="layout_vegetables" model="industry.theme.layout">
            <field name="name">Vegetables Soft Curvy Layout</field>
            <field name="border_radius">16px</field>
            <field name="button_style">pill</field>
            <field name="card_style">shadowed</field>
            <field name="shadow_style">0 8px 24px rgba(46,125,50,0.12)</field>
            <field name="animation_style">slide</field>
            <field name="spacing_scale">loose</field>
        </record>

        <record id="layout_fashion" model="industry.theme.layout">
            <field name="name">Fashion Sharp Flat Layout</field>
            <field name="border_radius">0px</field>
            <field name="button_style">flat</field>
            <field name="card_style">minimal</field>
            <field name="shadow_style">none</field>
            <field name="animation_style">fade</field>
            <field name="spacing_scale">loose</field>
        </record>

        <record id="layout_manufacturing" model="industry.theme.layout">
            <field name="name">Manufacturing Rigid Blocky Layout</field>
            <field name="border_radius">4px</field>
            <field name="button_style">rounded</field>
            <field name="card_style">bordered</field>
            <field name="shadow_style">0 2px 4px rgba(0,0,0,0.06)</field>
            <field name="animation_style">none</field>
            <field name="spacing_scale">normal</field>
        </record>

        <record id="layout_restaurant" model="industry.theme.layout">
            <field name="name">Restaurant Cozy Soft Layout</field>
            <field name="border_radius">20px</field>
            <field name="button_style">rounded</field>
            <field name="card_style">shadowed</field>
            <field name="shadow_style">0 10px 30px rgba(62,39,35,0.08)</field>
            <field name="animation_style">zoom</field>
            <field name="spacing_scale">loose</field>
        </record>

        <record id="layout_pharmacy" model="industry.theme.layout">
            <field name="name">Pharmacy Clinical Standard Layout</field>
            <field name="border_radius">8px</field>
            <field name="button_style">pill</field>
            <field name="card_style">bordered</field>
            <field name="shadow_style">0 4px 12px rgba(0,0,0,0.04)</field>
            <field name="animation_style">fade</field>
            <field name="spacing_scale">compact</field>
        </record>

        <!-- MAIN INDUSTRY THEMES SEED -->
        <record id="theme_vegetables" model="industry.theme">
            <field name="name">Vegetables Farm Theme</field>
            <field name="code">vegetables</field>
            <field name="category_id" ref="cat_vegetables"/>
            <field name="palette_id" ref="palette_vegetables"/>
            <field name="font_id" ref="font_vegetables"/>
            <field name="layout_id" ref="layout_vegetables"/>
            <field name="header_layout">default</field>
            <field name="footer_layout">default</field>
            <field name="shop_layout">grid</field>
            <field name="product_grid">4_cols</field>
            <field name="product_card_style">badge</field>
            <field name="category_card_style">circular</field>
            <field name="blog_style">grid</field>
            <field name="newsletter_style">default</field>
            <field name="whatsapp_enabled" eval="True"/>
            <field name="whatsapp_number">+1555019800</field>
            <field name="back_to_top_enabled" eval="True"/>
            <field name="loading_animation_enabled" eval="True"/>
            <field name="hover_effects_style">lift</field>
        </record>

        <record id="theme_fashion" model="industry.theme">
            <field name="name">Fashion Luxury Theme</field>
            <field name="code">fashion</field>
            <field name="category_id" ref="cat_fashion"/>
            <field name="palette_id" ref="palette_fashion"/>
            <field name="font_id" ref="font_fashion"/>
            <field name="layout_id" ref="layout_fashion"/>
            <field name="header_layout">transparent</field>
            <field name="footer_layout">dark</field>
            <field name="shop_layout">sidebar</field>
            <field name="product_grid">3_cols</field>
            <field name="product_card_style">hover_zoom</field>
            <field name="category_card_style">square</field>
            <field name="blog_style">masonry</field>
            <field name="newsletter_style">minimalist</field>
            <field name="whatsapp_enabled" eval="False"/>
            <field name="back_to_top_enabled" eval="True"/>
            <field name="loading_animation_enabled" eval="True"/>
            <field name="hover_effects_style">scale</field>
        </record>

        <record id="theme_manufacturing" model="industry.theme">
            <field name="name">Manufacturing Industrial Theme</field>
            <field name="code">manufacturing</field>
            <field name="category_id" ref="cat_manufacturing"/>
            <field name="palette_id" ref="palette_manufacturing"/>
            <field name="font_id" ref="font_manufacturing"/>
            <field name="layout_id" ref="layout_manufacturing"/>
            <field name="header_layout">default</field>
            <field name="footer_layout">multi_column</field>
            <field name="shop_layout">default</field>
            <field name="product_grid">3_cols</field>
            <field name="product_card_style">default</field>
            <field name="category_card_style">default</field>
            <field name="blog_style">default</field>
            <field name="newsletter_style">card</field>
            <field name="whatsapp_enabled" eval="True"/>
            <field name="whatsapp_number">+1555019801</field>
            <field name="back_to_top_enabled" eval="True"/>
            <field name="loading_animation_enabled" eval="False"/>
            <field name="hover_effects_style">none</field>
        </record>

        <record id="theme_restaurant" model="industry.theme">
            <field name="name">Restaurant Bistro Theme</field>
            <field name="code">restaurant</field>
            <field name="category_id" ref="cat_restaurant"/>
            <field name="palette_id" ref="palette_restaurant"/>
            <field name="font_id" ref="font_restaurant"/>
            <field name="layout_id" ref="layout_restaurant"/>
            <field name="header_layout">centered</field>
            <field name="footer_layout">default</field>
            <field name="shop_layout">grid</field>
            <field name="product_grid">3_cols</field>
            <field name="product_card_style">clean</field>
            <field name="category_card_style">circular</field>
            <field name="blog_style">grid</field>
            <field name="newsletter_style">default</field>
            <field name="whatsapp_enabled" eval="True"/>
            <field name="whatsapp_number">+1555019802</field>
            <field name="back_to_top_enabled" eval="True"/>
            <field name="loading_animation_enabled" eval="True"/>
            <field name="hover_effects_style">lift</field>
        </record>

        <record id="theme_pharmacy" model="industry.theme">
            <field name="name">Pharmacy Clinic Theme</field>
            <field name="code">pharmacy</field>
            <field name="category_id" ref="cat_pharmacy"/>
            <field name="palette_id" ref="palette_pharmacy"/>
            <field name="font_id" ref="font_pharmacy"/>
            <field name="layout_id" ref="layout_pharmacy"/>
            <field name="header_layout">default</field>
            <field name="footer_layout">multi_column</field>
            <field name="shop_layout">sidebar</field>
            <field name="product_grid">4_cols</field>
            <field name="product_card_style">badge</field>
            <field name="category_card_style">default</field>
            <field name="blog_style">default</field>
            <field name="newsletter_style">minimalist</field>
            <field name="whatsapp_enabled" eval="True"/>
            <field name="whatsapp_number">+1555019803</field>
            <field name="back_to_top_enabled" eval="True"/>
            <field name="loading_animation_enabled" eval="True"/>
            <field name="hover_effects_style">glow</field>
        </record>
    </data>
</odoo>
